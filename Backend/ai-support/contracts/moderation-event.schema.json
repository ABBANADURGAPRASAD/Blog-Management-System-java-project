{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blog.local/schemas/moderation-event.json",
  "title": "ModerationEvent",
  "type": "object",
  "required": ["eventType", "requestId", "idempotencyKey", "contentType", "contentId", "userId", "timestamp", "payload"],
  "properties": {
    "eventType": {
      "type": "string",
      "enum": ["MODERATION_REQUESTED", "MODERATION_COMPLETED", "MODERATION_FAILED"]
    },
    "requestId": { "type": "string", "format": "uuid" },
    "idempotencyKey": { "type": "string", "maxLength": 128 },
    "contentType": {
      "type": "string",
      "enum": ["POST", "COMMENT", "USER_PROFILE", "USER_BIO", "USER_AVATAR", "USER_MEDIA", "REEL", "CHAT_MESSAGE", "STORY", "APPEAL"]
    },
    "contentId": { "type": "integer" },
    "userId": { "type": "integer" },
    "priority": { "type": "integer", "minimum": 1, "maximum": 10, "default": 5 },
    "timestamp": { "type": "string", "format": "date-time" },
    "traceId": { "type": "string" },
    "payload": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "text": { "type": "string" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "mentionedUserIds": { "type": "array", "items": { "type": "integer" } },
        "media": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["url", "mediaType"],
            "properties": {
              "url": { "type": "string" },
              "mediaType": { "type": "string", "enum": ["image", "video", "pdf"] },
              "presigned": { "type": "boolean" }
            }
          }
        },
        "userName": { "type": "string" },
        "fullName": { "type": "string" },
        "bio": { "type": "string" }
      }
    },
    "result": {
      "type": "object",
      "description": "Present on MODERATION_COMPLETED",
      "required": ["finalStatus", "confidence", "scores"],
      "properties": {
        "finalStatus": { "type": "string", "enum": ["APPROVED", "WARNING", "BLOCKED"] },
        "commentClass": { "type": "string", "enum": ["SAFE", "WARNING", "BLOCKED"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "needsHumanReview": { "type": "boolean" },
        "detectedLanguage": { "type": "string" },
        "degradedMode": { "type": "boolean" },
        "processingMs": { "type": "integer" },
        "scores": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "score", "model"],
            "properties": {
              "label": { "type": "string" },
              "score": { "type": "number" },
              "model": { "type": "string" },
              "language": { "type": "string" }
            }
          }
        }
      }
    },
    "error": {
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
